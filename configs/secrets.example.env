# Copy to configs/secrets.env and fill in real values (do not commit secrets.env).

S3_ENDPOINT=https://your-s3-endpoint.com
S3_DOWNLOAD_ACCESS_KEY=your_download_access_key_here
S3_DOWNLOAD_SECRET_KEY=your_download_secret_key_here
S3_UPLOAD_ACCESS_KEY=your_upload_access_key_here
S3_UPLOAD_SECRET_KEY=your_upload_secret_key_here

YT_PROXY=your_yt_proxy_here
YT_TOKEN=your_yt_token_here